<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReferenceConsole"
        mc:Ignorable="d" d:DesignWidth="1360" d:DesignHeight="860"
        x:Class="ReferenceConsole.MainWindow"
        Width="1360" Height="860" MinWidth="1120" MinHeight="700"
        Icon="/Assets/rc-logo.ico"
        Background="{DynamicResource AppBg}"
        WindowDecorations="None"
        CanResize="True"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        Title="Register Broker Console">

  <Window.Resources>
    <!-- ============ Sensor row (inside a group) ============ -->
    <DataTemplate x:Key="SensorRowTemplate" x:DataType="local:SensorRow">
      <Grid ColumnDefinitions="*,Auto,90,46" Margin="2,3" Background="Transparent">
        <Grid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Rename…" Click="OnSensorRename"/>
            <MenuItem Header="Reset name" Click="OnSensorResetName"/>
          </ContextMenu>
        </Grid.ContextMenu>
        <TextBlock Grid.Column="0" Text="{Binding DisplayName}" Foreground="{DynamicResource TextPrimary}"
                   VerticalAlignment="Center"/>
        <TextBlock Grid.Column="1" Text="{Binding Id}" Classes="mono" FontSize="11" Margin="10,0,0,0"
                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"
                   IsVisible="{Binding ShowOrigin}"/>
        <TextBlock Grid.Column="2" Text="{Binding ValueText}" HorizontalAlignment="Right"
                   FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{DynamicResource TextPrimary}"
                   Classes.hot="{Binding IsHot}" Classes.active="{Binding IsActive}"/>
        <TextBlock Grid.Column="3" Text="{Binding Unit}" Margin="8,0,0,0"
                   Foreground="{DynamicResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
      </Grid>
    </DataTemplate>

    <!-- ============ Sensor group ============ -->
    <DataTemplate x:Key="SensorGroupTemplate" x:DataType="local:SensorGroup">
      <StackPanel Margin="0,0,0,10">
        <Border Background="{DynamicResource SurfaceInset}" CornerRadius="6" Padding="10,5" Margin="0,0,0,4">
          <TextBlock Text="{Binding Name}" Classes="group"/>
        </Border>
        <ItemsControl ItemsSource="{Binding Rows}" ItemTemplate="{StaticResource SensorRowTemplate}"
                      Margin="6,0,2,0"/>
      </StackPanel>
    </DataTemplate>

    <!-- ============ Activity entry ============ -->
    <DataTemplate x:Key="ActivityTemplate" x:DataType="local:ActivityEntry">
      <!-- Right margin keeps the right-aligned Tag badge clear of the list's vertical scrollbar. -->
      <Grid ColumnDefinitions="60,84,*,Auto" Margin="0,3,14,3">
        <TextBlock Grid.Column="0" Text="{Binding Time}" Classes="mono" FontSize="11"
                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
        <Border Grid.Column="1" Background="{Binding LevelBg}" CornerRadius="4" Padding="0,2"
                Margin="2,0,10,0" Height="20" VerticalAlignment="Center">
          <TextBlock Text="{Binding Level}" Foreground="{Binding LevelBrush}" FontSize="10"
                     FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <TextBlock Grid.Column="2" Text="{Binding Message}" Foreground="{DynamicResource TextSecondary}"
                   FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
        <Border Grid.Column="3" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource Border0}"
                BorderThickness="1" CornerRadius="4" Padding="6,1" VerticalAlignment="Center"
                IsVisible="{Binding HasTag}">
          <TextBlock Text="{Binding Tag}" Classes="mono" FontSize="10" Foreground="{DynamicResource TextSecondary}"/>
        </Border>
      </Grid>
    </DataTemplate>

    <!-- ============ RGB device card (ListBox item) ============ -->
    <DataTemplate x:Key="RgbDeviceTemplate" x:DataType="local:RgbRow">
      <Grid ColumnDefinitions="Auto,*" Margin="2" Background="Transparent">
        <Grid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Rename…" Click="OnRgbRename"/>
            <MenuItem Header="Reset name" Click="OnRgbResetName"/>
          </ContextMenu>
        </Grid.ContextMenu>
        <Ellipse Grid.Column="0" Width="9" Height="9" VerticalAlignment="Top" Margin="2,6,10,0"
                 Fill="{Binding StatusBrush}"/>
        <StackPanel Grid.Column="1" Spacing="2">
          <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                     TextWrapping="Wrap"/>
          <TextBlock Text="{Binding CardDetail}" Classes="muted" TextWrapping="Wrap"/>
        </StackPanel>
      </Grid>
    </DataTemplate>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="ListBox.devices">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="ListBox.devices ListBoxItem">
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Background" Value="{DynamicResource SurfaceAlt}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Border0}"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="ListBox.devices ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AccentSoft}"/>
    </Style>
    <Style Selector="ListBox.devices ListBoxItem:selected">
      <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
    </Style>

    <!-- box drag bar -->
    <Style Selector="Grid.dragbar">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>
    <Style Selector="Grid.dragbar:pointerover TextBlock.handle">
      <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
    </Style>
  </Window.Styles>

  <!-- Outer resize frame: 6px grips on every edge/corner drive BeginResizeDrag (borderless window). -->
  <Grid ColumnDefinitions="6,*,6" RowDefinitions="6,*,6" Background="Transparent">
    <Border Grid.Row="0" Grid.Column="0" Background="Transparent" Cursor="TopLeftCorner" PointerPressed="OnResizeNW"/>
    <Border Grid.Row="0" Grid.Column="1" Background="Transparent" Cursor="TopSide" PointerPressed="OnResizeN"/>
    <Border Grid.Row="0" Grid.Column="2" Background="Transparent" Cursor="TopRightCorner" PointerPressed="OnResizeNE"/>
    <Border Grid.Row="1" Grid.Column="0" Background="Transparent" Cursor="LeftSide" PointerPressed="OnResizeW"/>
    <Border Grid.Row="1" Grid.Column="2" Background="Transparent" Cursor="RightSide" PointerPressed="OnResizeE"/>
    <Border Grid.Row="2" Grid.Column="0" Background="Transparent" Cursor="BottomLeftCorner" PointerPressed="OnResizeSW"/>
    <Border Grid.Row="2" Grid.Column="1" Background="Transparent" Cursor="BottomSide" PointerPressed="OnResizeS"/>
    <Border Grid.Row="2" Grid.Column="2" Background="Transparent" Cursor="BottomRightCorner" PointerPressed="OnResizeSE"/>

  <Grid Grid.Row="1" Grid.Column="1" RowDefinitions="44,*,Auto">

    <!-- ================= ROW 0: custom chrome ================= -->
    <Border Grid.Row="0" Background="{DynamicResource ChromeBg}" PointerPressed="OnChromeDrag"
            DoubleTapped="OnChromeMaximize">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,0">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Image Width="30" Height="30" Source="avares://ReferenceConsole/Assets/rc-logo.png"
                 RenderOptions.BitmapInterpolationMode="HighQuality"/>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Register Broker Reference Console" FontWeight="SemiBold" FontSize="13"
                       Foreground="{DynamicResource TextPrimary}"/>
          </StackPanel>
        </StackPanel>

        <!-- Borderless window: these are our own window controls (no native caption). -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
            <TextBlock Text="☀" FontSize="13" Margin="0,0,9,0" Foreground="{DynamicResource TextSecondary}"
                       VerticalAlignment="Center"/>
            <ToggleSwitch x:Name="ThemeToggle" OnContent="" OffContent="" IsChecked="True"
                          Width="44" MinWidth="0" Padding="0" Margin="0" Click="OnThemeToggle" VerticalAlignment="Center"/>
            <TextBlock Text="☾" FontSize="12" Margin="9,0,0,0" Foreground="{DynamicResource TextSecondary}"
                       VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center" Margin="6,0,0,0">
            <Button Classes="chrome" Content="—" Click="OnChromeMinimize" ToolTip.Tip="Minimize"/>
            <Button Classes="chrome" Content="▢" Click="OnChromeMaximizeBtn" ToolTip.Tip="Maximize"/>
            <Button Classes="chrome close" Content="✕" Click="OnChromeClose" ToolTip.Tip="Close"/>
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ================= ROW 1: sidebar + content ================= -->
    <Grid Grid.Row="1" ColumnDefinitions="212,*">

      <!-- ===== sidebar ===== -->
      <Border Grid.Column="0" Background="{DynamicResource ChromeBg}" BorderBrush="{DynamicResource Border0}"
              BorderThickness="0,0,1,0">
        <Grid RowDefinitions="*,Auto" Margin="12,14">
          <StackPanel Grid.Row="0" Spacing="3">
            <Button x:Name="NavDashboard" Classes="nav active" Click="OnNavDashboard" Content="◧   Dashboard"/>
            <Button x:Name="NavSensors"   Classes="nav" Click="OnNavSensors"   Content="∿   Sensors"/>
            <Button x:Name="NavRgb"       Classes="nav" Click="OnNavRgb"       Content="◉   RGB"/>
            <!-- User-created sections live at the bottom, just above "Add Section" (the fixed pages
                 above aren't reorderable, so new boards collect here and can be drag-reordered). -->
            <StackPanel x:Name="SectionNavHost" Spacing="3"/>
            <Button x:Name="AddSectionButton" Classes="nav" Click="OnAddSection" Content="＋   Add Section"
                    ToolTip.Tip="Create a new, empty dashboard section you can fill with cards"/>
          </StackPanel>

          <StackPanel Grid.Row="1" Spacing="8">
            <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Content="⧉  GitHub" Click="OnOpenGitHub"/>
            <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Content="ⓘ  About" Click="OnAbout"/>
            <Button x:Name="NavSettings" Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Content="⚙  Settings" Click="OnNavSettings"/>
            <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Content="✉  Send feedback" Click="OnSendFeedback"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ===== content host ===== -->
      <Panel Grid.Column="1" x:Name="ContentHost">

        <!-- ============ DASHBOARD PAGE ============ -->
        <!-- Fixed containment box: a toolbar row + a fill row that holds the card canvas. The fill
             row sizes itself to the window (so it grows with the monitor/resolution), and cards are
             clamped to that row so they can never cross its edges. -->
        <Grid x:Name="PageDashboard" Margin="16" RowDefinitions="Auto,*">

            <!-- layout toolbar -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,12">
              <TextBlock Grid.Column="0" Text="Dashboard" Classes="h1" VerticalAlignment="Center"/>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right"
                          VerticalAlignment="Center">
                <Button x:Name="GridModeBtn" Classes="seg on" Content="▦ Grid" Click="OnGridMode"
                        ToolTip.Tip="Anchored grid: boxes auto-arrange and snap into rows"/>
                <Button x:Name="FreeModeBtn" Classes="seg" Content="✥ Free" Click="OnFreeMode"
                        ToolTip.Tip="Free placement: drag boxes anywhere on the canvas"/>
                <Button x:Name="AddBoxButton" Classes="ghost" Content="＋ Add Card" Click="OnAddBox"/>
                <Button Classes="ghost" Content="↺ Reset layout" Click="OnResetLayout"/>
                <TextBlock Text="🔒 Lock cards" Classes="sub" VerticalAlignment="Center" Margin="6,0,0,0"/>
                <ToggleSwitch x:Name="DashLockToggle" OnContent="" OffContent="" MinWidth="0"
                              VerticalAlignment="Center" Click="OnDashLockToggle"
                              ToolTip.Tip="Freeze the dashboard cards — when on, cards can't be moved or resized"/>
              </StackPanel>
            </Grid>

            <!-- containment area: cards live on the Canvas; ClipToBounds keeps them inside it. The
                 WrapPanel is only the XAML authoring host — boxes are moved onto the Canvas at startup. -->
            <Panel Grid.Row="1" ClipToBounds="True">
              <Canvas x:Name="DashCanvas" IsVisible="False"/>
              <WrapPanel x:Name="DashGrid" IsVisible="False">

              <!-- ===== metric: CPU ===== -->
              <Border Classes="card box" Tag="cpu" Width="200" Margin="0,0,14,14">
                <DockPanel>
                  <Grid Classes="dragbar" DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto"
                        PointerPressed="OnBoxDragStart" PointerMoved="OnBoxDragMove" PointerReleased="OnBoxDragEnd">
                    <TextBlock Grid.Column="0" Classes="handle" Text="⠿" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="CPU Temperature" Classes="sub" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Classes="iconbtn" Content="✕" Click="OnBoxRemove"/>
                  </Grid>
                  <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Border Width="26" Height="26" CornerRadius="7" Background="#2A2350">
                        <TextBlock Text="CPU" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource Accent}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>
                      <TextBlock x:Name="CpuVal" Text="—" FontSize="26" FontWeight="Bold"
                                 Foreground="{DynamicResource TextPrimary}"/>
                      <TextBlock Text="°C" Classes="sub" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
                    </StackPanel>
                    <local:Sparkline x:Name="CpuSpark" Height="32" Stroke="{DynamicResource Accent}"/>
                  </StackPanel>
                </DockPanel>
              </Border>

              <!-- ===== metric: GPU ===== -->
              <Border Classes="card box" Tag="gpu" Width="200" Margin="0,0,14,14">
                <DockPanel>
                  <Grid Classes="dragbar" DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto"
                        PointerPressed="OnBoxDragStart" PointerMoved="OnBoxDragMove" PointerReleased="OnBoxDragEnd">
                    <TextBlock Grid.Column="0" Classes="handle" Text="⠿" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="GPU Temperature" Classes="sub" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Classes="iconbtn" Content="✕" Click="OnBoxRemove"/>
                  </Grid>
                  <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Border x:Name="GpuBadge" Width="26" Height="26" CornerRadius="7" Background="#16321F">
                        <TextBlock x:Name="GpuBadgeText" Text="GPU" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource Green}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>
                      <TextBlock x:Name="GpuVal" Text="—" FontSize="26" FontWeight="Bold"
                                 Foreground="{DynamicResource TextPrimary}"/>
                      <TextBlock Text="°C" Classes="sub" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
                    </StackPanel>
                    <local:Sparkline x:Name="GpuSpark" Height="32" Stroke="{DynamicResource Green}"/>
                  </StackPanel>
                </DockPanel>
              </Border>

              <!-- ===== metric: VRM ===== -->
              <Border Classes="card box" Tag="vrm" Width="200" Margin="0,0,14,14">
                <DockPanel>
                  <Grid Classes="dragbar" DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto"
                        PointerPressed="OnBoxDragStart" PointerMoved="OnBoxDragMove" PointerReleased="OnBoxDragEnd">
                    <TextBlock Grid.Column="0" Classes="handle" Text="⠿" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="VRM MOS" Classes="sub" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Classes="iconbtn" Content="✕" Click="OnBoxRemove"/>
                  </Grid>
                  <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Border Width="26" Height="26" CornerRadius="7" Background="#2A2350">
                        <TextBlock Text="VRM" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource Accent}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>
                      <TextBlock x:Name="VrmVal" Text="—" FontSize="26" FontWeight="Bold"
                                 Foreground="{DynamicResource TextPrimary}"/>
                      <TextBlock Text="°C" Classes="sub" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
                    </StackPanel>
                    <local:Sparkline x:Name="VrmSpark" Height="32" Stroke="{DynamicResource Accent}"/>
                  </StackPanel>
                </DockPanel>
              </Border>

              <!-- ===== metric: System ===== -->
              <Border Classes="card box" Tag="sys" Width="200" Margin="0,0,14,14">
                <DockPanel>
                  <Grid Classes="dragbar" DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto"
                        PointerPressed="OnBoxDragStart" PointerMoved="OnBoxDragMove" PointerReleased="OnBoxDragEnd">
                    <TextBlock Grid.Column="0" Classes="handle" Text="⠿" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="System Temp" Classes="sub" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Classes="iconbtn" Content="✕" Click="OnBoxRemove"/>
                  </Grid>
                  <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Border Width="26" Height="26" CornerRadius="7" Background="#16293F">
                        <TextBlock Text="SYS" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource Blue}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>
                      <TextBlock x:Name="SysVal" Text="—" FontSize="26" FontWeight="Bold"
                                 Foreground="{DynamicResource TextPrimary}"/>
                      <TextBlock Text="°C" Classes="sub" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
                    </StackPanel>
                    <local:Sparkline x:Name="SysSpark" Height="32" Stroke="{DynamicResource Blue}"/>
                  </StackPanel>
                </DockPanel>
              </Border>

              <!-- ===== metric: Latency ===== -->
              <Border Classes="card box" Tag="lat" Width="200" Margin="0,0,14,14">
                <DockPanel>
                  <Grid Classes="dragbar" DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto"
                        PointerPressed="OnBoxDragStart" PointerMoved="OnBoxDragMove" PointerReleased="OnBoxDragEnd">
                    <TextBlock Grid.Column="0" Classes="handle" Text="⠿" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Broker Latency" Classes="sub" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Classes="iconbtn" Content="✕" Click="OnBoxRemove"/>
                  </Grid>
                  <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Border Width="26" Height="26" CornerRadius="7" Background="#0F3038">
                        <TextBlock Text="LAT" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource Cyan}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>
                      <TextBlock x:Name="LatVal" Text="—" FontSize="26" FontWeight="Bold"
                                 Foreground="{DynamicResource TextPrimary}"/>
                      <TextBlock Text="ms" Classes="sub" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
                    </StackPanel>
                    <local:Sparkline x:Name="LatSpark" Height="32" Stroke="{DynamicResource Cyan}"/>
                  </StackPanel>
                </DockPanel>
              </Border>

              <!-- ===== Sensors panel ===== -->
              <Border Classes="card box" Tag="sensors" Width="450" Height="470" Margin="0,0,14,14">
                <DockPanel>
                  <Grid Classes="dragbar" DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto"
                        PointerPressed="OnBoxDragStart" PointerMoved="OnBoxDragMove" PointerReleased="OnBoxDragEnd">
                    <TextBlock Grid.Column="0" Classes="handle" Text="⠿" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Sensors" Classes="h2" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Classes="iconbtn" Content="✕" Click="OnBoxRemove"/>
                  </Grid>
                  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="SensorGroupsDash" ItemTemplate="{StaticResource SensorGroupTemplate}"/>
                  </ScrollViewer>
                </DockPanel>
              </Border>

              <!-- ===== RGB Devices (shell; hosts the shared device list — see MountRgbPanels) ===== -->
              <Border Classes="card box" Tag="devices" Width="210" Height="470" Margin="0,0,14,14">
                <DockPanel>
                  <Grid Classes="dragbar" DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto"
                        PointerPressed="OnBoxDragStart" PointerMoved="OnBoxDragMove" PointerReleased="OnBoxDragEnd">
                    <TextBlock Grid.Column="0" Classes="handle" Text="⠿" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="RGB Devices" Classes="h2" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Classes="iconbtn" Content="✕" Click="OnBoxRemove"/>
                  </Grid>
                  <ContentControl x:Name="RgbCardDevicesHost"/>
                </DockPanel>
              </Border>

              <!-- ===== RGB Control (shell; hosts the shared device-options editor) ===== -->
              <Border Classes="card box" Tag="control" Width="430" Height="470" Margin="0,0,14,14">
                <DockPanel>
                  <Grid Classes="dragbar" DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto"
                        PointerPressed="OnBoxDragStart" PointerMoved="OnBoxDragMove" PointerReleased="OnBoxDragEnd">
                    <TextBlock Grid.Column="0" Classes="handle" Text="⠿" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="RGB Control" Classes="h2" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Classes="iconbtn" Content="✕" Click="OnBoxRemove"/>
                  </Grid>
                  <ContentControl x:Name="RgbCardControlHost"/>
                </DockPanel>
              </Border>

              <!-- ===== Activity ===== -->
              <Border Classes="card box" Tag="activity" Width="690" Height="280" Margin="0,0,14,14">
                <DockPanel>
                  <Grid Classes="dragbar" DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto,Auto"
                        PointerPressed="OnBoxDragStart" PointerMoved="OnBoxDragMove" PointerReleased="OnBoxDragEnd">
                    <TextBlock Grid.Column="0" Classes="handle" Text="⠿" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Activity" Classes="h2" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="Clear" Classes="ghost" Click="OnClearActivity" Margin="0,0,6,0"/>
                    <Button Grid.Column="3" Classes="iconbtn" Content="✕" Click="OnBoxRemove"/>
                  </Grid>
                  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ActivityListDash" ItemTemplate="{StaticResource ActivityTemplate}"/>
                  </ScrollViewer>
                </DockPanel>
              </Border>

              <!-- ===== Security / Permissions ===== -->
              <Border Classes="card box" Tag="security" Width="380" Height="280" Margin="0,0,14,14">
                <DockPanel>
                  <Grid Classes="dragbar" DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto,Auto"
                        PointerPressed="OnBoxDragStart" PointerMoved="OnBoxDragMove" PointerReleased="OnBoxDragEnd">
                    <TextBlock Grid.Column="0" Classes="handle" Text="⠿" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Security / Permissions" Classes="h2" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="Details" Classes="ghost" Click="OnNavSettings" Margin="0,0,6,0"/>
                    <Button Grid.Column="3" Classes="iconbtn" Content="✕" Click="OnBoxRemove"/>
                  </Grid>
                  <StackPanel Spacing="6">
                    <TextBlock Text="Granted scopes" Classes="muted"/>
                    <WrapPanel x:Name="GrantedChips"/>
                    <TextBlock Text="Denied scopes" Classes="muted" Margin="0,6,0,0"/>
                    <WrapPanel>
                      <Border Background="{DynamicResource RedSoft}" CornerRadius="5" Padding="8,2" Margin="0,0,6,6">
                        <TextBlock Text="✕ driver:raw" Classes="mono" FontSize="11" Foreground="{DynamicResource Red}"/>
                      </Border>
                      <Border Background="{DynamicResource RedSoft}" CornerRadius="5" Padding="8,2" Margin="0,0,6,6">
                        <TextBlock Text="✕ admin" Classes="mono" FontSize="11" Foreground="{DynamicResource Red}"/>
                      </Border>
                      <Border Background="{DynamicResource RedSoft}" CornerRadius="5" Padding="8,2" Margin="0,0,6,6">
                        <TextBlock Text="✕ kernel-memory" Classes="mono" FontSize="11" Foreground="{DynamicResource Red}"/>
                      </Border>
                    </WrapPanel>
                  </StackPanel>
                </DockPanel>
              </Border>

              </WrapPanel>
            </Panel>
        </Grid>

        <!-- ============ SENSORS PAGE ============ -->
        <Grid x:Name="PageSensors" IsVisible="False" Margin="16">
          <Border Classes="card">
            <Grid RowDefinitions="Auto,*">
              <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
                <TextBlock Grid.Column="0" Text="Sensors" Classes="h1" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="16,0"
                            VerticalAlignment="Center">
                  <ToggleButton x:Name="SensorPollToggle" Content="Live poll" Classes="ghost"
                                Click="OnSensorPollToggle" Padding="9,4"/>
                  <NumericUpDown x:Name="PollInterval" Minimum="250" Maximum="10000" Increment="250"
                                 Value="1000" Width="124"/>
                  <Button Content="Read once" Classes="ghost" Click="OnSensorReadOnce"/>
                  <TextBlock x:Name="SensorCount" Classes="muted" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <TextBlock Text="Show origins" Classes="muted" VerticalAlignment="Center"/>
                  <ToggleSwitch x:Name="OriginsTogglePage" OnContent="" OffContent="" MinWidth="0"
                                Click="OnToggleOrigins"/>
                </StackPanel>
              </Grid>
              <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="SensorGroupsPage" ItemTemplate="{StaticResource SensorGroupTemplate}"/>
              </ScrollViewer>
            </Grid>
          </Border>
        </Grid>

        <!-- ============ RGB PAGE ============ -->
        <!-- Dedicated RGB view. The device list + options editor are SHARED single controls
             (RgbDevicesBody / RgbControlBody) reparented between here and the dashboard cards by
             MountRgbPanels, so both places use one set of controls (no duplicate logic). -->
        <Grid x:Name="PageRgb" IsVisible="False" Margin="16" ColumnDefinitions="280,*">

          <!-- devices -->
          <Border Grid.Column="0" Classes="card" Margin="0,0,14,0">
            <Grid RowDefinitions="Auto,*">
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                <TextBlock Grid.Column="0" Text="RGB Devices" Classes="h1" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Refresh" Classes="ghost" Click="OnRgbRefresh"/>
              </Grid>
              <ContentControl Grid.Row="1" x:Name="RgbPageDevicesHost">
                <ScrollViewer x:Name="RgbDevicesBody" HorizontalScrollBarVisibility="Disabled">
                  <ListBox x:Name="RgbDeviceList" Classes="devices" SelectionChanged="OnRgbDeviceSelected"
                           ItemTemplate="{StaticResource RgbDeviceTemplate}"/>
                </ScrollViewer>
              </ContentControl>
            </Grid>
          </Border>

          <!-- control -->
          <Border Grid.Column="1" Classes="card">
            <ContentControl x:Name="RgbPageControlHost">
              <DockPanel x:Name="RgbControlBody">
                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                  <StackPanel Grid.Column="0">
                    <TextBlock x:Name="RgbSelected" Text="No device selected" Classes="h2"/>
                    <TextBlock x:Name="RgbSelectedSub" Text="Select a device from the list" Classes="muted"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Live control" Classes="sub" VerticalAlignment="Center"/>
                    <ToggleSwitch x:Name="DriveCheck" OnContent="" OffContent="" MinWidth="0" Click="OnDriveToggled"/>
                  </StackPanel>
                </Grid>
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                  <StackPanel x:Name="EditorPanel" Spacing="12" IsVisible="False">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" RowDefinitions="Auto,Auto" RowSpacing="8">
                      <TextBlock Grid.Row="0" Grid.Column="0" Text="Effect" Classes="sub" VerticalAlignment="Center"/>
                      <ComboBox Grid.Row="0" Grid.Column="1" x:Name="EffectCombo" HorizontalAlignment="Stretch"
                                SelectionChanged="OnEffectChanged"/>
                      <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="ApplyOnce" Content="Apply to selected" Classes="primary" Click="OnApplyOnce"/>
                        <Button Content="Apply to all" Classes="ghost" Click="OnDriveAll"/>
                      </StackPanel>
                    </Grid>

                    <TextBlock Text="Live preview" Classes="muted"/>
                    <Border Background="{DynamicResource SurfaceInset}" BorderBrush="{DynamicResource Border0}"
                            BorderThickness="1" CornerRadius="8" Padding="8" MinHeight="40">
                      <ItemsControl x:Name="LedPreview">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="local:LedCell">
                            <Border Width="15" Height="15" Margin="2" CornerRadius="3"
                                    Background="{Binding Brush}" BorderBrush="#10000000" BorderThickness="1"
                                    Tag="{Binding Index}" PointerPressed="OnLedPainted"/>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Border>

                    <StackPanel x:Name="ManualTools" Orientation="Horizontal" Spacing="10" IsVisible="False">
                      <Button Content="Fill with brush" Classes="ghost" Click="OnManualFill"/>
                      <Button Content="Clear" Classes="ghost" Click="OnManualClear"/>
                      <TextBlock Text="click LEDs above to paint" Classes="muted" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Parameters" Classes="muted"/>
                    <StackPanel x:Name="ParamPanel" Spacing="10"/>
                  </StackPanel>
                </ScrollViewer>
              </DockPanel>
            </ContentControl>
          </Border>
        </Grid>

        <!-- ============ SETTINGS PAGE ============ -->
        <!-- The single hub: connection, startup, render knobs, the activity feed, and the
             security/permissions panels (the former Activity + Security pages folded in here).
             The cards live on a Canvas and are drag-movable + resizable like the dashboard; the
             "Lock cards" toggle freezes them in place (see SetupSettingsCards in code-behind). -->
        <Grid x:Name="PageSettings" IsVisible="False" Margin="16" RowDefinitions="Auto,*">

          <!-- toolbar -->
          <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,12">
            <TextBlock Grid.Column="0" Text="Settings" Classes="h1" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right"
                        VerticalAlignment="Center">
              <TextBlock Text="🔒 Lock cards" Classes="sub" VerticalAlignment="Center"/>
              <ToggleSwitch x:Name="SettingsLockToggle" OnContent="" OffContent="" MinWidth="0"
                            VerticalAlignment="Center" Click="OnSettingsLockToggle"
                            ToolTip.Tip="Freeze the settings cards — when on, cards can't be moved or resized"/>
              <Button Classes="ghost" Content="↺ Reset layout" Click="OnResetSettingsLayout"
                      ToolTip.Tip="Restore the default settings card arrangement"/>
            </StackPanel>
          </Grid>

          <!-- card canvas (vertical scroll for overflow; cards are absolute-positioned) -->
          <ScrollViewer Grid.Row="1" x:Name="SettingsScroll" HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <!-- Top/left anchored: a Canvas with an explicit Height would otherwise be CENTERED in the
                 viewport, pushing its Y=0 origin to mid-page so the top half couldn't be reached. -->
            <Canvas x:Name="SettingsCanvas" VerticalAlignment="Top" HorizontalAlignment="Stretch">

              <Border Classes="card" Tag="connection" Width="540">
                <StackPanel Spacing="12">
                  <StackPanel Classes="sdragbar" Orientation="Horizontal" Spacing="8" Background="Transparent">
                    <TextBlock Classes="handle" Text="⠿" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="Connection" Classes="h2" VerticalAlignment="Center"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button x:Name="ConnectButton" Content="Connect" Classes="primary" Click="OnConnectClick"/>
                    <Button Content="Ping broker" Classes="ghost" Click="OnPing"/>
                    <TextBlock x:Name="EngineStatus" Text="Connect to drive devices." Classes="sub"
                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                  </StackPanel>
                </StackPanel>
              </Border>

              <!-- ===== Startup ===== -->
              <Border Classes="card" Tag="startup" Width="540">
                <StackPanel Spacing="12">
                  <StackPanel Classes="sdragbar" Orientation="Horizontal" Spacing="8" Background="Transparent">
                    <TextBlock Classes="handle" Text="⠿" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="Startup" Classes="h2" VerticalAlignment="Center"/>
                  </StackPanel>
                  <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="12">
                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2" Margin="0,0,24,0">
                      <TextBlock Text="Start console on login" Classes="sub"/>
                      <TextBlock Text="Launch this reference console automatically when you sign in to Windows."
                                 Classes="muted" TextWrapping="Wrap"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Row="0" Grid.Column="1" x:Name="AutoStartGuiToggle" OnContent="" OffContent=""
                                  MinWidth="0" VerticalAlignment="Center" Click="OnAutoStartGuiToggle"/>
                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2" Margin="0,0,24,0">
                      <TextBlock Text="Start broker services on login" Classes="sub"/>
                      <TextBlock Text="Set the Register Broker services to start with Windows. Applying this needs administrator rights — the preference is saved and applied on the next elevated start if it can't be set now."
                                 Classes="muted" TextWrapping="Wrap"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Row="1" Grid.Column="1" x:Name="AutoStartServicesToggle" OnContent="" OffContent=""
                                  MinWidth="0" VerticalAlignment="Center" Click="OnAutoStartServicesToggle"/>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="card" Tag="render" Width="540">
                <StackPanel Spacing="12">
                  <StackPanel Classes="sdragbar" Orientation="Horizontal" Spacing="8" Background="Transparent">
                    <TextBlock Classes="handle" Text="⠿" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="Render &amp; polling" Classes="h2" VerticalAlignment="Center"/>
                  </StackPanel>
                  <Grid ColumnDefinitions="*,160" RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="RGB frame rate (FPS)" Classes="sub" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Row="0" Grid.Column="1" x:Name="FpsBox" Minimum="1" Maximum="60" Increment="1"
                                   Value="20" FormatString="0" ValueChanged="OnFpsChanged"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Sensor refresh (ms)" Classes="sub" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Row="1" Grid.Column="1" x:Name="RefreshMsBox" Minimum="100" Maximum="10000"
                                   Increment="50" Value="750" FormatString="0" ValueChanged="OnRefreshMsChanged"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Minimize to" Classes="sub" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="MinimizeTargetCombo" HorizontalAlignment="Stretch"
                              SelectionChanged="OnMinimizeTargetChanged">
                      <ComboBoxItem>Taskbar</ComboBoxItem>
                      <ComboBoxItem>Tray</ComboBoxItem>
                    </ComboBox>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="card" Tag="rgbengine" Width="540">
                <StackPanel Spacing="8">
                  <StackPanel Classes="sdragbar" Orientation="Horizontal" Spacing="8" Background="Transparent">
                    <TextBlock Classes="handle" Text="⠿" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="RGB engine" Classes="h2" VerticalAlignment="Center"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Refresh devices" Classes="ghost" Click="OnRgbRefresh"/>
                    <Button Content="Stop all devices" Classes="ghost" Click="OnStopAll"/>
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Classes="card" Tag="dashlayout" Width="540">
                <StackPanel Spacing="8">
                  <StackPanel Classes="sdragbar" Orientation="Horizontal" Spacing="8" Background="Transparent">
                    <TextBlock Classes="handle" Text="⠿" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="Dashboard layout" Classes="h2" VerticalAlignment="Center"/>
                  </StackPanel>
                  <TextBlock Text="Drag a box by its title bar to reorder it. Use the ✕ on a box to remove it, and “Add box” on the Dashboard to bring it back." Classes="sub" TextWrapping="Wrap"/>
                  <Button Content="Reset dashboard layout" Classes="ghost" Click="OnResetLayout" HorizontalAlignment="Left"/>
                </StackPanel>
              </Border>

              <!-- ===== Activity (the former Activity page, folded into Settings) ===== -->
              <!-- "Raw log" swaps the structured feed for the raw diagnostics text in place, so the
                   card keeps a single fixed footprint instead of an oversized expander. -->
              <!-- Height drives the feed/raw fill: the content row is "*", so both views grow and
                   shrink with the card (resize the card → more rows visible) instead of a fixed cap. -->
              <Border Classes="card" Tag="activity" Width="540" Height="340">
                <Grid RowDefinitions="Auto,*">
                  <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                    <StackPanel Grid.Column="0" Classes="sdragbar" Orientation="Horizontal" Spacing="8"
                                Background="Transparent" VerticalAlignment="Center">
                      <TextBlock Classes="handle" Text="⠿" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}"/>
                      <TextBlock Text="Activity" Classes="h2" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                      <TextBlock Text="Raw log" Classes="sub" VerticalAlignment="Center"/>
                      <ToggleSwitch x:Name="RawLogToggle" OnContent="" OffContent="" MinWidth="0"
                                    VerticalAlignment="Center" Click="OnRawLogToggle"/>
                      <Button Content="Ping broker" Classes="ghost" Click="OnPing"/>
                      <Button Content="Clear" Classes="ghost" Click="OnClearActivity"/>
                    </StackPanel>
                  </Grid>
                  <!-- Both views share the same row, font size, and right margin so toggling Raw log
                       keeps the text the same size and the card filled identically. -->
                  <Panel Grid.Row="1">
                    <ScrollViewer x:Name="ActivityFeedScroll" HorizontalScrollBarVisibility="Disabled">
                      <ItemsControl x:Name="ActivityListPage" ItemTemplate="{StaticResource ActivityTemplate}"/>
                    </ScrollViewer>
                    <ScrollViewer x:Name="RawLogScroll" HorizontalScrollBarVisibility="Disabled"
                                  IsVisible="False">
                      <SelectableTextBlock x:Name="LogBox" Classes="mono" FontSize="13" LineHeight="22"
                                           Margin="0,3,14,3" Foreground="{DynamicResource TextSecondary}"/>
                    </ScrollViewer>
                  </Panel>
                </Grid>
              </Border>

              <!-- ===== Security / Permissions — Scopes (folded in from the Security page) ===== -->
              <Border Classes="card" Tag="security" Width="540">
                <StackPanel Spacing="10">
                  <StackPanel Classes="sdragbar" Orientation="Horizontal" Spacing="8" Background="Transparent">
                    <TextBlock Classes="handle" Text="⠿" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="Security &amp; Permissions" Classes="h2" VerticalAlignment="Center"/>
                  </StackPanel>
                  <TextBlock Text="The broker grants only the scopes this client requested and is authorized for. Everything else is refused in-kernel." Classes="sub" TextWrapping="Wrap"/>
                  <TextBlock Text="Granted" Classes="muted" Margin="0,6,0,0"/>
                  <WrapPanel x:Name="GrantedChipsPage"/>
                  <TextBlock Text="Denied" Classes="muted" Margin="0,6,0,0"/>
                  <WrapPanel>
                    <Border Background="{DynamicResource RedSoft}" CornerRadius="6" Padding="10,4" Margin="0,0,8,8">
                      <TextBlock Text="✕ driver:raw" Classes="mono" FontSize="12" Foreground="{DynamicResource Red}"/>
                    </Border>
                    <Border Background="{DynamicResource RedSoft}" CornerRadius="6" Padding="10,4" Margin="0,0,8,8">
                      <TextBlock Text="✕ admin" Classes="mono" FontSize="12" Foreground="{DynamicResource Red}"/>
                    </Border>
                    <Border Background="{DynamicResource RedSoft}" CornerRadius="6" Padding="10,4" Margin="0,0,8,8">
                      <TextBlock Text="✕ kernel-memory" Classes="mono" FontSize="12" Foreground="{DynamicResource Red}"/>
                    </Border>
                    <Border Background="{DynamicResource RedSoft}" CornerRadius="6" Padding="10,4" Margin="0,0,8,8">
                      <TextBlock Text="✕ physical-memory" Classes="mono" FontSize="12" Foreground="{DynamicResource Red}"/>
                    </Border>
                  </WrapPanel>
                </StackPanel>
              </Border>

              <!-- ===== Security / Permissions — Client Identity ===== -->
              <Border Classes="card" Tag="identity" Width="540">
                <StackPanel Spacing="10">
                  <StackPanel Classes="sdragbar" Orientation="Horizontal" Spacing="8" Background="Transparent">
                    <TextBlock Classes="handle" Text="⠿" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="Client Identity" Classes="h2" VerticalAlignment="Center"/>
                  </StackPanel>
                  <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Client" Classes="sub"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Register Broker Reference Console" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="User" Classes="sub"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SecUser" Text="—" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Integrity" Classes="sub"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="SecIntegrity" Text="—" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Signed" Classes="sub"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="SecSigned" Text="—" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Session" Classes="sub"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="SecSession" Text="Non-admin" Foreground="{DynamicResource TextPrimary}"/>
                  </Grid>
                  <Border Background="{DynamicResource GreenSoft}" BorderBrush="{DynamicResource Green}"
                          BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,6,0,0">
                    <Grid ColumnDefinitions="Auto,*">
                      <TextBlock Grid.Column="0" Text="🛡" FontSize="22" Foreground="{DynamicResource Green}"
                                 VerticalAlignment="Center" Margin="0,0,10,0"/>
                      <TextBlock Grid.Column="1" Text="Hardware access is brokered, scoped, and audited — no admin or kernel rights are granted to this client."
                                 Classes="sub" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </Grid>
                  </Border>
                </StackPanel>
              </Border>

            </Canvas>
          </ScrollViewer>
        </Grid>
      </Panel>
    </Grid>

    <!-- ================= ROW 3: footer ================= -->
    <!-- ================= ROW 2: consolidated status bar (was the top bar + footer, merged) ========= -->
    <Border Grid.Row="2" Background="{DynamicResource ChromeBg}" BorderBrush="{DynamicResource Border0}"
            BorderThickness="0,1,0,0" Padding="16,6">
      <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
        <Ellipse x:Name="ConnDot" Width="9" Height="9" Fill="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
        <TextBlock x:Name="ConnText" Text="Disconnected" Margin="8,0,16,0" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>

        <Border x:Name="ChipSensors" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource Border0}"
                BorderThickness="1" CornerRadius="5" Padding="8,2" Margin="0,0,6,0" Opacity="0.4">
          <TextBlock Text="sensors:read" Classes="mono" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
        </Border>
        <Border x:Name="ChipRgb" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource Border0}"
                BorderThickness="1" CornerRadius="5" Padding="8,2" Margin="0,0,16,0" Opacity="0.4">
          <TextBlock Text="rgb:write" Classes="mono" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
        </Border>

        <TextBlock Text="Session:" Classes="muted" VerticalAlignment="Center"/>
        <TextBlock x:Name="SessionText" Text="—" Margin="5,0,16,0" FontSize="12"
                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>

        <TextBlock Text="Broker:" Classes="muted" VerticalAlignment="Center"/>
        <TextBlock x:Name="BrokerText" Text="Offline" Margin="5,0,16,0" FontSize="12" FontWeight="Medium"
                   Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>

        <TextBlock Text="Latency:" Classes="muted" VerticalAlignment="Center"/>
        <TextBlock x:Name="LatencyText" Text="— ms" Margin="5,0,16,0" FontSize="12"
                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>

        <TextBlock Text="Poll:" Classes="muted" VerticalAlignment="Center"/>
        <TextBlock x:Name="PollText" Text="— ms" Margin="5,0,16,0" FontSize="12"
                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>

        <TextBlock Text="Devices:" Classes="muted" VerticalAlignment="Center"/>
        <TextBlock x:Name="DevicesText" Text="0" Margin="5,0,16,0" FontSize="12"
                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>

        <TextBlock Text="Sensors:" Classes="muted" VerticalAlignment="Center"/>
        <TextBlock x:Name="SensorsCountText" Text="0" Margin="5,0,16,0" FontSize="12"
                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>

        <TextBlock x:Name="FootThroughput" Text="Throughput: idle" Classes="muted" Margin="0,0,16,0"
                   VerticalAlignment="Center"/>
        <TextBlock x:Name="FootUptime" Text="Uptime: 00:00:00" Classes="muted" VerticalAlignment="Center"/>
      </StackPanel>
    </Border>
  </Grid>
  </Grid>
</Window>
